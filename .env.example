# Portfolio Tracker — Required Environment Variables
# Copy to .env and fill in values

# Firebase Admin SDK credentials (JSON string)
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Paste the ENTIRE JSON file contents as a single string
FIREBASE_CREDENTIALS_JSON=

# Cron endpoint secret (required in production)
# Generate: openssl rand -hex 32
# Set in Vercel: Settings > Environment Variables
# Also set in Vercel Cron header: Authorization: Bearer <this-value>
CRON_SECRET=

# Optional: Custom CORS origin (e.g., https://app.moljuurtei.com)
# If not set, only localhost:3000 and the Vercel deploy URL are allowed
CORS_ORIGIN=

# Vercel sets these automatically — do not set manually
# VERCEL=1
